<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_task_row"
    android:layout_width="match_parent"
    android:layout_height="48dp"
    android:background="@drawable/widget_row_background"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="6dp">

    <CheckBox
        android:id="@+id/widget_task_check"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:buttonTint="@color/widget_text" />

    <TextView
        android:id="@+id/widget_task_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/widget_text"
        android:textSize="15sp" />

    <TextView
        android:id="@+id/widget_task_line"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingStart="6dp"
        android:paddingEnd="0dp"
        android:textColor="@color/widget_text"
        android:textSize="11sp" />

</LinearLayout>
