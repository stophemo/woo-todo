{
  "name": "@woo-todo/backend",
  "version": "0.1.11",
  "private": true,
  "type": "module",
  "description": "woo-todo 的 Cloudflare Workers + D1 密文同步服务",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply woo-todo --local",
    "db:migrate:remote": "wrangler d1 migrations apply woo-todo --remote",
    "test": "node --test test/*.test.ts",
    "typecheck": "tsc -p tsconfig.json"
  },
  "engines": {
    "node": ">=22.18"
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "wrangler": "^4.0.0"
  }
}
