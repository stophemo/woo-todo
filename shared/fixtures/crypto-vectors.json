{
  "formatVersion": 1,
  "description": "woo-todo 跨端确定性 ID 与应用层密文 golden vectors。所有二进制字段均使用无填充 Base64URL。",
  "encoding": "base64url-no-padding",
  "occurrenceId": {
    "description": "将规范字符串按 UTF-8 编码，取 SHA-256 摘要前 16 字节，再设置 UUID version 5 与 RFC 4122 variant 位。此算法不等同于基于 SHA-1 namespace 的标准 UUIDv5。",
    "namespace": "woo-todo-occurrence-v1",
    "canonicalFormat": "{namespace}|{seriesIdLowercase}|{timeType}|{periodStartYYYY-MM-DD}",
    "digest": "SHA-256",
    "digestPrefixBytes": 16,
    "uuidVersion": 5,
    "uuidVariant": "RFC-4122",
    "vectors": [
      {
        "name": "每日任务与大写 series ID 归一化",
