{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://woo-todo.dev/schema/backup-plaintext.schema.json",
  "title": "woo-todo 备份解密正文",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocolVersion", "exportedAt", "tasks", "syncCredentials"],
  "properties": {
    "protocolVersion": { "const": 1 },
    "exportedAt": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "tasks": {
      "type": "array",
      "maxItems": 50000,
      "items": { "$ref": "task.schema.json#/$defs/TaskPayload" }
    },
    "tombstones": {
      "description": "v0.1.1 起可选；缺失时按空数组处理。任务与删除记录合计不得超过 50000 条。",
      "type": "array",
      "maxItems": 50000,
      "items": { "$ref": "task.schema.json#/$defs/TombstonePayload" }
    },
    "syncCredentials": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["endpoint", "vaultId", "deviceId", "deviceToken", "vaultKey"],
          "properties": {
            "endpoint": { "type": "string", "format": "uri", "maxLength": 2048 },
            "vaultId": { "type": "string", "minLength": 1, "maxLength": 128 },
            "deviceId": { "type": "string", "minLength": 1, "maxLength": 128 },
            "deviceToken": {
              "type": "string",
              "pattern": "^[A-Za-z0-9_-]{43}$"
            },
            "vaultKey": {
              "type": "string",
              "pattern": "^[A-Za-z0-9_-]{43}$"
            }
          }
        }
      ]
    }
  }
}
