{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://woo-todo.dev/schema/backup.schema.json",
  "title": "woo-todo 加密备份文件",
  "type": "object",
  "additionalProperties": false,
  "required": ["format", "version", "createdAt", "kdf", "cipher"],
  "properties": {
    "format": { "const": "woo-todo-backup" },
    "version": { "const": 1 },
    "createdAt": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "kdf": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "iterations", "salt"],
      "properties": {
        "algorithm": { "const": "pbkdf2-hmac-sha256" },
        "iterations": {
          "type": "integer",
          "minimum": 100000,
          "maximum": 2000000
        },
        "salt": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]{22}$"
        }
      }
    },
    "cipher": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "nonce", "ciphertext"],
      "properties": {
        "algorithm": { "const": "aes-256-gcm" },
        "nonce": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]{16}$"
        },
        "ciphertext": {
          "type": "string",
          "minLength": 22,
          "maxLength": 44739243,
          "pattern": "^[A-Za-z0-9_-]+$"
        }
      }
    }
  }
}
