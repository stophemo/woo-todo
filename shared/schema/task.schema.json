{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://woo-todo.dev/schema/task.schema.json",
  "title": "woo-todo 任务与显示配置密文正文协议",
  "$defs": {
    "TimeType": {
      "type": "string",
      "enum": ["day", "week", "month", "someday"]
    },
    "QuestLine": {
      "type": "string",
      "enum": ["main", "side", "extra"]
    },
    "TaskState": {
      "type": "string",
      "enum": ["pending", "completed", "pass"]
    },
    "TaskPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "protocolVersion", "entityType", "id", "seriesId", "title",
        "timeType", "periodStart", "timezone", "questLine", "state",
        "recurrence", "sortOrder", "createdAt", "updatedAt", "settledAt"
      ],
      "properties": {
        "protocolVersion": { "const": 1 },
        "entityType": { "const": "task" },
        "id": {
          "type": "string",
          "minLength": 8,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9._:-]+$"
        },
        "seriesId": {
          "type": "string",
          "minLength": 8,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9._:-]+$"
        },
        "title": { "type": "string", "minLength": 1, "maxLength": 120 },
        "timeType": { "$ref": "#/$defs/TimeType" },
        "periodStart": {
          "type": ["string", "null"],
          "format": "date",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$",
          "description": "day 使用合法公历日期；week 必须为周一；month 必须为每月 1 日。week 的星期语义由客户端与共享 fixture 校验。"
        },
        "timezone": { "const": "Asia/Shanghai" },
        "questLine": { "$ref": "#/$defs/QuestLine" },
        "state": { "$ref": "#/$defs/TaskState" },
        "recurrence": { "type": "string", "enum": ["once", "repeat"] },
        "sortOrder": { "type": "integer", "minimum": 0, "maximum": 2147483647 },
        "createdAt": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
        "updatedAt": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
        "reminderTime": {
          "type": ["string", "null"],
          "pattern": "^(?:[01][0-9]|2[0-3]):[0-5][0-9]$",
          "description": "可选提醒墙钟时间，按任务 timezone 与 periodStart 解释；旧正文缺少该字段时等同 null。"
        },
        "settledAt": {
          "type": ["integer", "null"],
          "minimum": 0,
          "maximum": 9007199254740991
        }
      },
      "allOf": [
        {
          "if": { "properties": { "timeType": { "const": "someday" } } },
          "then": {
            "properties": {
              "periodStart": { "type": "null" },
              "recurrence": { "const": "once" },
              "reminderTime": { "type": "null" }
            }
          },
          "else": { "properties": { "periodStart": { "type": "string" } } }
        },
        {
          "if": { "properties": { "timeType": { "const": "month" } } },
          "then": {
            "properties": {
              "periodStart": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-01$" }
            }
          }
        },
        {
          "if": { "properties": { "state": { "const": "pending" } } },
          "then": { "properties": { "settledAt": { "type": "null" } } },
          "else": { "properties": { "settledAt": { "type": "integer" } } }
        }
      ]
    },
    "TombstonePayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocolVersion", "entityType", "id", "deletedAt"],
      "properties": {
        "protocolVersion": { "const": 1 },
        "entityType": { "const": "tombstone" },
        "id": {
          "type": "string",
          "minLength": 8,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9._:-]+$"
        },
        "deletedAt": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 }
      }
    },
    "DisplayConfigurationPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "protocolVersion", "entityType", "id", "headerTemplate",
        "subtitleTemplate", "startDate", "deadlineDate"
      ],
      "properties": {
        "protocolVersion": { "const": 1 },
        "entityType": { "const": "displayConfiguration" },
        "id": { "const": "display.today.configuration" },
        "headerTemplate": {
          "type": "string",
          "maxLength": 80,
          "pattern": "^[^\\r\\n\\u000B\\u000C\\u0085\\u2028\\u2029]*$",
          "description": "今日面板标题模板；空字符串表示不显示标题，未知模板变量按原文保留。"
        },
        "subtitleTemplate": {
          "type": "string",
          "maxLength": 160,
          "pattern": "^[^\\r\\n\\u000B\\u000C\\u0085\\u2028\\u2029]*$",
          "description": "今日面板副标题模板；空字符串表示不显示副标题，未知模板变量按原文保留。"
        },
        "startDate": {
          "type": "string",
          "format": "date",
          "pattern": "^(?!0000)[0-9]{4}-[0-9]{2}-[0-9]{2}$"
        },
        "deadlineDate": {
          "type": "string",
          "format": "date",
          "pattern": "^(?!0000)[0-9]{4}-[0-9]{2}-[0-9]{2}$"
        }
      }
    }
  },
  "oneOf": [
    { "$ref": "#/$defs/TaskPayload" },
    { "$ref": "#/$defs/TombstonePayload" },
    { "$ref": "#/$defs/DisplayConfigurationPayload" }
  ]
}
